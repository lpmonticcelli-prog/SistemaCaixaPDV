<Window x:Class="SistemaCaixaPDV.TelaPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Menu Principal - PDV Itapira" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="#F4F7FC"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="ModernCardButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent" BorderThickness="2" CornerRadius="25" Margin="10">
                            <Border.Effect>
                                <DropShadowEffect Color="Gray" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00E1D9"/>
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00E1D9" BlurRadius="20" ShadowDepth="5" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="0,0,30,30" Padding="20,30,20,30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E3A8A" Offset="0.0"/>
                    <GradientStop Color="#6D28D9" Offset="0.7"/>
                    <GradientStop Color="#00E1D9" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="👋 Olá, bem-vindo de volta!" FontSize="20" Foreground="#E0E7FF" FontWeight="Medium"/>
                    <TextBlock x:Name="txtNomeLoja" Text="Sistema PDV Inteligente" FontSize="36" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="txtRelogio" Text="12:00" FontSize="36" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="txtData" Text="Segunda-feira, 01 de Janeiro" FontSize="16" Foreground="#E0E7FF" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,30,0,0">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnOrdemServico_Click">
                    <StackPanel>
                        <TextBlock Text="🛠️" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="ORDEM SERVIÇO" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#D97706"/>
                        <TextBlock Text="Oficina / Assistência" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnPdvRapido_Click">
                    <StackPanel>
                        <TextBlock Text="🛒" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="PDV RÁPIDO" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#10B981"/>
                        <TextBlock Text="Frente de Caixa (F5)" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnPdv_Click">
                    <StackPanel>
                        <TextBlock Text="🖥️" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="VENDAS" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#2563EB"/>
                        <TextBlock Text="Venda Detalhada" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnEmissorNFe_Click">
                    <StackPanel>
                        <TextBlock Text="📄" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="EMISSOR NF-e" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#0284C7"/>
                        <TextBlock Text="Nota Fiscal Grande (A4)" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnProdutos_Click">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="PRODUTOS" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#F59E0B"/>
                        <TextBlock Text="Estoque e Preços" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnClientes_Click">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="CLIENTES" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#3B82F6"/>
                        <TextBlock Text="Cadastro e Histórico" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnRelatorios_Click">
                    <StackPanel>
                        <TextBlock Text="📈" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="RELATÓRIOS" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#EC4899"/>
                        <TextBlock Text="Listas e Filtros" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnCaixa_Click">
                    <StackPanel>
                        <TextBlock Text="📊" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="FECHAMENTO" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#8B5CF6"/>
                        <TextBlock Text="Histórico de Vendas" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnDespesas_Click">
                    <StackPanel>
                        <TextBlock Text="💸" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="DESPESAS" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#F43F5E"/>
                        <TextBlock Text="Contas a Pagar" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnReceber_Click">
                    <StackPanel>
                        <TextBlock Text="📒" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="A RECEBER" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#059669"/>
                        <TextBlock Text="Crediário e Parcelas" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnConfig_Click">
                    <StackPanel>
                        <TextBlock Text="⚙️" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="CONFIGURAÇÕES" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#475569"/>
                        <TextBlock Text="Empresa, PIX, Logo" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <Button Width="220" Height="220" Style="{StaticResource ModernCardButton}" Click="btnSair_Click">
                    <StackPanel>
                        <TextBlock Text="🚪" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="SAIR" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#EF4444"/>
                        <TextBlock Text="Encerrar Sistema" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

            </WrapPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="2" Text="© 2026 - Desenvolvido para máxima agilidade no seu dia a dia!" FontSize="12" Foreground="Gray" HorizontalAlignment="Left" Margin="10,5,0,10"/>
    </Grid>
</Window>