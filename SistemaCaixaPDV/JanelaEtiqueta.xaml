<Window x:Class="SistemaCaixaPDV.JanelaEtiqueta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Imprimir Etiqueta" Height="250" Width="350" WindowStartupLocation="CenterScreen" Background="#E2E8F0">
    <Grid>
        <Border x:Name="areaEtiqueta" Width="280" Height="150" Background="White" BorderBrush="Black" BorderThickness="1" Margin="10,10,10,50" Padding="10">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="lblNomeLoja" Text="NOME DA LOJA" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBlock x:Name="lblDescricao" Text="NOME DO PRODUTO" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,0" FontWeight="SemiBold"/>
                <TextBlock x:Name="lblPreco" Text="R$ 0,00" FontSize="26" HorizontalAlignment="Center" FontWeight="Black" Margin="0,5,0,0"/>
                <TextBlock x:Name="lblCodigo" Text="CÓD: 123456" FontSize="12" FontFamily="Courier New" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Button Content="🖨️ Enviar para Impressora" Width="180" Height="30" VerticalAlignment="Bottom" Margin="0,0,0,10" Background="#10B981" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="btnImprimir_Click"/>
    </Grid>
</Window>