<Window x:Class="SistemaCaixaPDV.TelaDesconto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aplicar Desconto" Height="438" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" Background="#F8FAFC"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="💸 APLICAR DESCONTO" FontSize="22" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="Total da Venda:" FontSize="16" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="txtTotalOriginal" Text="R$ 0,00" FontSize="20" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBlock Text="Porcentagem do Desconto (%):" FontSize="14" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center"/>
            <TextBox x:Name="txtPorcentagem" Width="120" Height="50" FontSize="30" FontWeight="Bold" TextAlignment="Center" Foreground="#10B981" Margin="0,5,0,0" TextChanged="txtPorcentagem_TextChanged"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#FEF2F2" Margin="20,0,20,20" Padding="10">
            <StackPanel>
                <TextBlock Text="Valor que será descontado:" FontSize="12" Foreground="#991B1B" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtValorDesconto" Text="- R$ 0,00" FontSize="24" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="4" Content="APROVAR DESCONTO (ENTER)" FontSize="16" FontWeight="Bold" Background="#16A34A" Foreground="White" Height="45" VerticalAlignment="Bottom" Click="btnConfirmar_Click" Cursor="Hand"/>
    </Grid>
</Window>