<Window x:Class="SistemaCaixaPDV.TelaCadastroProduto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WV Systems - Cadastro de Produtos e Serviços" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        KeyDown="Window_KeyDown" Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
            <WrapPanel Orientation="Horizontal">
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Click="btnNovo_Click" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Novo (F2)" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnGravar" Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Click="btnGravar_Click" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="💾" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Gravar (F3)" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnLocalizar" Width="100" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnLocalizar_Click">
                    <StackPanel>
                        <TextBlock Text="🔍" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Localizar Produto&#x0a;(F6)" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnExcluir_Click">
                    <StackPanel>
                        <TextBlock Text="🗑️" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Excluir" FontSize="10" Foreground="Red" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnImprimirEtiqueta_Click">
                    <StackPanel>
                        <TextBlock Text="🏷️" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Imprimir&#x0a;Etiqueta" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="📑" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Duplicar&#x0a;Registro" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Width="100" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnImprimirRelatorio_Click">
                    <StackPanel>
                        <TextBlock Text="🖨️" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Imprimir Rel.&#x0a;de Produtos" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Width="80" Height="60" Margin="20,2,2,2" Background="Transparent" BorderThickness="0" Click="btnFechar_Click" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="Fechar" FontSize="16" Foreground="Red" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="&lt;   &gt;" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="5" Background="White">
            <TabItem Header="Cadastro Produto/Serviço" FontWeight="Bold" FontSize="14">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Código/Cód. Barras" Foreground="Gray"/>
                                <TextBox x:Name="txtCodigo" Height="25" Background="#E5E7EB" TextAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Gerar" Margin="5,15,5,0" Height="25" Click="btnGerarCodigo_Click"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Descrição" Foreground="Gray"/>
                                <TextBox x:Name="txtDescricao" Height="25"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Unidade" Foreground="Gray"/>
                                <ComboBox x:Name="cbUnidade" Height="25" Text="UN" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                <TextBlock Text="Preço de Compra" Foreground="Gray"/>
                                <TextBox x:Name="txtPrecoCompra" Height="25" Text="0,00" TextAlignment="Center" TextChanged="CalculoMargem_TextChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                                <TextBlock Text="Margem/Markup" Foreground="Gray"/>
                                <TextBox x:Name="txtMargem" Height="25" Text="100,00" TextAlignment="Center" TextChanged="CalculoMargem_TextChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,5,0">
                                <TextBlock Text="Lucro (R$)" Foreground="Gray"/>
                                <TextBox x:Name="txtLucro" Height="25" Text="0,00" TextAlignment="Center" IsReadOnly="True" Background="#F3F4F6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="0,0,5,0">
                                <TextBlock Text="Preço de Venda" Foreground="Gray"/>
                                <TextBox x:Name="txtPrecoVenda" Height="25" Text="0,00" TextAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5">
                                <TextBlock Text="Preço aPrazo/Atacado" Foreground="Gray" FontSize="11"/>
                                <TextBox x:Name="txtPrecoPrazo" Height="25" Text="0,00" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Grupo" Foreground="Gray"/>
                                <ComboBox Height="25" Text="Geral" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                <TextBlock Text="Sub-Grupo" Foreground="Gray"/>
                                <ComboBox Height="25" Text="Geral" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                                <TextBlock Text="Fornecedor" Foreground="Gray"/>
                                <ComboBox Height="25" Text="Fornecedor Padrão" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Est.Mínimo" Foreground="Gray"/>
                                <TextBox x:Name="txtEstoqueMinimo" Height="25" Text="0" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Garantia" Foreground="Gray"/>
                                <TextBox Height="25"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                <TextBlock Text="Marca" Foreground="Gray"/>
                                <TextBox Height="25" Text="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                                <TextBlock Text="Referência" Foreground="Gray"/>
                                <TextBox Height="25" Text="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,5,0">
                                <TextBlock Text="Validade (xx/xx/xxxx)" Foreground="Gray" FontSize="11"/>
                                <TextBox Height="25"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Comissão %" Foreground="Gray"/>
                                <TextBox Height="25" Text="0,00" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Localização:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" Height="25" Margin="0,0,10,0"/>
                            <CheckBox Grid.Column="2" Content="Este produto possui Grade/Variação?" Foreground="Gray" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Observações:" Foreground="Gray" Margin="0,0,5,0"/>
                            <TextBox x:Name="txtObservacoes" Grid.Column="1" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9FAFB"/>
                        </Grid>

                        <GroupBox Header="⚙️ Dados Fiscais (Obrigatório para Cupom Fiscal)" BorderBrush="#3B82F6" Foreground="#1E3A8A" FontWeight="Bold" Margin="0,0,0,10" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="NCM (8 Dígitos)" Foreground="Gray" FontWeight="Normal"/>
                                    <TextBox x:Name="txtNcm" Height="25" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                    <TextBlock Text="CFOP" Foreground="Gray" FontWeight="Normal"/>
                                    <TextBox x:Name="txtCfop" Height="25" Text="5102" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="CSOSN / CST (Tributação)" Foreground="Gray" FontWeight="Normal"/>
                                    <ComboBox x:Name="cbCsosn" Height="25" IsEditable="True" Text="102 - Tributada pelo Simples (Sem ST)">
                                        <ComboBoxItem Content="102 - Tributada pelo Simples (Sem ST)"/>
                                        <ComboBoxItem Content="500 - ICMS Cobrado Anteriormente por ST"/>
                                        <ComboBoxItem Content="400 - Não Tributada"/>
                                        <ComboBoxItem Content="101 - Tributada pelo Simples com Permissão de Crédito"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                    </StackPanel>

                    <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Foto Produto" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Border BorderBrush="LightGray" BorderThickness="1" Height="150" Background="#F9FAFB" Margin="0,0,0,10">
                                <Image x:Name="imgProduto" Stretch="Uniform"/>
                            </Border>
                            <Button Content="Inserir Foto" Height="25" Margin="0,0,0,5" Click="btnInserirFoto_Click"/>
                            <TextBlock Text="Atenção aos arquivos de imagem compatível bmp, jpg ou png" Foreground="Gray" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" FontStyle="Italic" Margin="0,0,0,15"/>

                            <TextBlock Text="Estoque Atual:" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtEstoqueAtual" Text="0" FontSize="20" FontWeight="Bold" TextAlignment="Center" Background="#FEF08A" Height="35"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Histórico de Compra" FontWeight="Bold" FontSize="14">
                <Grid Background="#F8FAFC" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#E0F2FE" CornerRadius="5" Padding="10" Margin="0,0,0,15" BorderBrush="#BAE6FD" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Fornecedor:" FontWeight="Bold" FontSize="11" Foreground="#0369A1"/>
                                    <TextBox x:Name="txtEntradaFornecedor" Width="150" Height="25"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Nº NF-e:" FontWeight="Bold" FontSize="11" Foreground="#0369A1"/>
                                    <TextBox x:Name="txtEntradaNFe" Width="100" Height="25"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Qtd Entrada:" FontWeight="Bold" FontSize="11" Foreground="#0369A1"/>
                                    <TextBox x:Name="txtEntradaQtd" Width="70" Height="25" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="Custo Un. (R$):" FontWeight="Bold" FontSize="11" Foreground="#0369A1"/>
                                    <TextBox x:Name="txtEntradaCusto" Width="80" Height="25" TextAlignment="Center"/>
                                </StackPanel>
                                <Button Content="➕ Lançar Manual" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="10,0" Height="25" Margin="0,15,0,0" Click="btnLancarEntradaManual_Click" Cursor="Hand"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="📄 Importar XML NF-e" Background="#F59E0B" Foreground="White" FontWeight="Bold" Padding="15,0" Height="35" Click="btnImportarXML_Click" Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1" Text="Últimas entradas (compras) registradas para este produto:" FontWeight="SemiBold" Foreground="#1E3A8A" Margin="0,0,0,10" FontSize="14"/>

                    <DataGrid x:Name="gridHistoricoCompras" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="White" AlternatingRowBackground="#F1F5F9" RowHeight="28"
                              HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="#E2E8F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data da Compra" Binding="{Binding DataCompra}" Width="140"/>
                            <DataGridTextColumn Header="Fornecedor" Binding="{Binding Fornecedor}" Width="*"/>
                            <DataGridTextColumn Header="Nº NFe" Binding="{Binding NumeroNFe}" Width="100"/>
                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="80"/>
                            <DataGridTextColumn Header="Custo Un." Binding="{Binding CustoUnitario}" Width="110"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Histórico de Venda" FontWeight="Bold" FontSize="14">
                <Grid Background="#F8FAFC" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Últimas saídas (vendas) registradas para este produto:" FontWeight="SemiBold" Foreground="#1E3A8A" Margin="0,0,0,10" FontSize="14"/>
                    <DataGrid x:Name="gridHistoricoVendas" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="White" AlternatingRowBackground="#F1F5F9" RowHeight="28"
                              HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="#E2E8F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data da Venda" Binding="{Binding DataVenda}" Width="140"/>
                            <DataGridTextColumn Header="Nº Venda" Binding="{Binding NumVenda}" Width="100"/>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}" Width="*"/>
                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="80"/>
                            <DataGridTextColumn Header="Valor Un." Binding="{Binding ValorUnitario}" Width="110"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="#E0F2FE" Padding="10" Margin="0,10,0,0" CornerRadius="5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Total Vendido (Qtd): " FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTotalQtdVenda" Text="0,00" FontWeight="Black" Foreground="#0284C7" FontSize="18" Margin="0,0,25,0" VerticalAlignment="Center"/>

                            <TextBlock Text="Valor Arrecadado: " FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTotalValorVenda" Text="R$ 0,00" FontWeight="Black" Foreground="#166534" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Conferência Estoque" FontWeight="Bold" FontSize="14">
                <Grid Background="#F8FAFC" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FEF3C7" CornerRadius="5" Padding="10" Margin="0,0,0,15" BorderBrush="#FDE047" BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Tipo de Ajuste:" FontWeight="Bold" FontSize="11" Foreground="#B45309"/>
                                    <ComboBox x:Name="cbAjusteTipo" Width="170" Height="25">
                                        <ComboBoxItem Content="Entrada Avulsa" IsSelected="True"/>
                                        <ComboBoxItem Content="Saída (Perda/Avaria)"/>
                                        <ComboBoxItem Content="Balanço (Substituir)"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Quantidade:" FontWeight="Bold" FontSize="11" Foreground="#B45309"/>
                                    <TextBox x:Name="txtAjusteQtd" Width="80" Height="25" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="Motivo / Observação:" FontWeight="Bold" FontSize="11" Foreground="#B45309"/>
                                    <TextBox x:Name="txtAjusteMotivo" Width="200" Height="25"/>
                                </StackPanel>
                                <Button Content="⚖️ Lançar Ajuste" Background="#D97706" Foreground="White" FontWeight="Bold" Padding="10,0" Height="25" Margin="0,15,0,0" Click="btnLancarAjuste_Click" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1" Text="Extrato de movimentações manuais e balanços:" FontWeight="SemiBold" Foreground="#1E3A8A" Margin="0,0,0,10" FontSize="14"/>

                    <DataGrid x:Name="gridHistoricoEstoque" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="White" AlternatingRowBackground="#FFFBEB" RowHeight="28"
                              HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="#E2E8F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data do Ajuste" Binding="{Binding DataHora}" Width="140"/>
                            <DataGridTextColumn Header="Tipo de Movimento" Binding="{Binding Tipo}" Width="160"/>
                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="80"/>
                            <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Grade/Variação" FontWeight="Bold" FontSize="14">
                <Grid Background="#F8FAFC" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F3E8FF" CornerRadius="5" Padding="10" Margin="0,0,0,15" BorderBrush="#D8B4FE" BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Atributo (Ex: Cor, Tamanho):" FontWeight="Bold" FontSize="11" Foreground="#6B21A8"/>
                                    <ComboBox x:Name="cbVariacaoAtributo" Width="170" Height="25" IsEditable="True">
                                        <ComboBoxItem Content="Tamanho" IsSelected="True"/>
                                        <ComboBoxItem Content="Cor"/>
                                        <ComboBoxItem Content="Voltagem"/>
                                        <ComboBoxItem Content="Sabor"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Valor (Ex: M, Azul, 110V):" FontWeight="Bold" FontSize="11" Foreground="#6B21A8"/>
                                    <TextBox x:Name="txtVariacaoValor" Width="150" Height="25"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Cód. Barras (Opcional):" FontWeight="Bold" FontSize="11" Foreground="#6B21A8"/>
                                    <TextBox x:Name="txtVariacaoCodigo" Width="130" Height="25"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="Estoque:" FontWeight="Bold" FontSize="11" Foreground="#6B21A8"/>
                                    <TextBox x:Name="txtVariacaoEstoque" Width="70" Height="25" TextAlignment="Center" Text="0"/>
                                </StackPanel>
                                <Button Content="➕ Adicionar Variação" Background="#8B5CF6" Foreground="White" FontWeight="Bold" Padding="10,0" Height="25" Margin="0,15,0,0" Click="btnAdicionarVariacao_Click" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="gridVariacoes" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="White" AlternatingRowBackground="#FAF5FF" RowHeight="28"
                              HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="#E2E8F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Atributo" Binding="{Binding Atributo}" Width="120"/>
                            <DataGridTextColumn Header="Valor" Binding="{Binding Valor}" Width="150"/>
                            <DataGridTextColumn Header="Código de Barras" Binding="{Binding CodigoBarras}" Width="180"/>
                            <DataGridTextColumn Header="Estoque" Binding="{Binding Estoque}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>