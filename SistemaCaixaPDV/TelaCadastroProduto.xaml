<Window x:Class="SistemaCaixaPDV.TelaCadastroProduto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de produtos e serviços" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        KeyDown="Window_KeyDown" Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
            <WrapPanel Orientation="Horizontal">
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Click="btnNovo_Click" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Novo (F2)" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnGravar" Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Click="btnGravar_Click" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="💾" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Gravar (F3)" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnLocalizar" Width="100" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnLocalizar_Click">
                    <StackPanel>
                        <TextBlock Text="🔍" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Localizar Produto&#x0a;(F6)" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnExcluir_Click">
                    <StackPanel>
                        <TextBlock Text="🗑️" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Excluir" FontSize="10" Foreground="Red" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="🏷️" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Imprimir&#x0a;Etiqueta" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="📑" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Duplicar&#x0a;Registro" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="100" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="🖨️" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Imprimir Rel.&#x0a;de Produtos" TextAlignment="Center" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="80" Height="60" Margin="20,2,2,2" Background="Transparent" BorderThickness="0" Click="btnFechar_Click" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="Fechar" FontSize="16" Foreground="Red" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="&lt;   &gt;" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="5" Background="White">
            <TabItem Header="Cadastro Produto/Serviço" FontWeight="Bold" FontSize="14">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Código/Cód. Barras" Foreground="Gray"/>
                                <TextBox x:Name="txtCodigo" Height="25" Background="#E5E7EB" TextAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Gerar" Margin="5,15,5,0" Height="25" Click="btnGerarCodigo_Click"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Descrição" Foreground="Gray"/>
                                <TextBox x:Name="txtDescricao" Height="25"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Unidade" Foreground="Gray"/>
                                <ComboBox x:Name="cbUnidade" Height="25" Text="UN" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                <TextBlock Text="Preço de Compra" Foreground="Gray"/>
                                <TextBox x:Name="txtPrecoCompra" Height="25" Text="0,00" TextAlignment="Center" TextChanged="CalculoMargem_TextChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                                <TextBlock Text="Margem/Markup" Foreground="Gray"/>
                                <TextBox x:Name="txtMargem" Height="25" Text="100,00" TextAlignment="Center" TextChanged="CalculoMargem_TextChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,5,0">
                                <TextBlock Text="Lucro (R$)" Foreground="Gray"/>
                                <TextBox x:Name="txtLucro" Height="25" Text="0,00" TextAlignment="Center" IsReadOnly="True" Background="#F3F4F6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="0,0,5,0">
                                <TextBlock Text="Preço de Venda" Foreground="Gray"/>
                                <TextBox x:Name="txtPrecoVenda" Height="25" Text="0,00" TextAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5">
                                <TextBlock Text="Preço aPrazo/Atacado" Foreground="Gray" FontSize="11"/>
                                <TextBox x:Name="txtPrecoPrazo" Height="25" Text="0,00" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Grupo" Foreground="Gray"/>
                                <ComboBox Height="25" Text="Geral" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                <TextBlock Text="Sub-Grupo" Foreground="Gray"/>
                                <ComboBox Height="25" Text="Geral" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                                <TextBlock Text="Fornecedor" Foreground="Gray"/>
                                <ComboBox Height="25" Text="Fornecedor Padrão" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Est.Mínimo" Foreground="Gray"/>
                                <TextBox x:Name="txtEstoqueMinimo" Height="25" Text="0" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Garantia" Foreground="Gray"/>
                                <TextBox Height="25"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                <TextBlock Text="Marca" Foreground="Gray"/>
                                <TextBox Height="25" Text="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                                <TextBlock Text="Referência" Foreground="Gray"/>
                                <TextBox Height="25" Text="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,5,0">
                                <TextBlock Text="Validade (xx/xx/xxxx)" Foreground="Gray" FontSize="11"/>
                                <TextBox Height="25"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Comissão %" Foreground="Gray"/>
                                <TextBox Height="25" Text="0,00" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Localização:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" Height="25" Margin="0,0,10,0"/>
                            <CheckBox Grid.Column="2" Content="Este produto possui Grade/Variação?" Foreground="Gray" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Observações:" Foreground="Gray" Margin="0,0,5,0"/>
                            <TextBox x:Name="txtObservacoes" Grid.Column="1" Height="40" TextWrapping="Wrap" AcceptsReturn="True" Background="#F9FAFB"/>
                        </Grid>

                        <GroupBox Header="⚙️ Dados Fiscais (Obrigatório para Cupom Fiscal)" BorderBrush="#3B82F6" Foreground="#1E3A8A" FontWeight="Bold" Margin="0,0,0,10" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="NCM (8 Dígitos)" Foreground="Gray" FontWeight="Normal"/>
                                    <TextBox x:Name="txtNcm" Height="25" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                    <TextBlock Text="CFOP" Foreground="Gray" FontWeight="Normal"/>
                                    <TextBox x:Name="txtCfop" Height="25" Text="5102" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="CSOSN / CST (Tributação)" Foreground="Gray" FontWeight="Normal"/>
                                    <ComboBox x:Name="cbCsosn" Height="25" IsEditable="True" Text="102 - Tributada pelo Simples (Sem ST)">
                                        <ComboBoxItem Content="102 - Tributada pelo Simples (Sem ST)"/>
                                        <ComboBoxItem Content="500 - ICMS Cobrado Anteriormente por ST"/>
                                        <ComboBoxItem Content="400 - Não Tributada"/>
                                        <ComboBoxItem Content="101 - Tributada pelo Simples com Permissão de Crédito"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                    </StackPanel>

                    <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Foto Produto" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Border BorderBrush="LightGray" BorderThickness="1" Height="150" Background="#F9FAFB" Margin="0,0,0,10">
                                <Image x:Name="imgProduto" Stretch="Uniform"/>
                            </Border>
                            <Button Content="Inserir Foto" Height="25" Margin="0,0,0,5" Click="btnInserirFoto_Click"/>
                            <TextBlock Text="Atenção aos arquivos de imagem compatível bmp, jpg ou png" Foreground="Gray" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" FontStyle="Italic" Margin="0,0,0,15"/>

                            <TextBlock Text="Estoque Atual:" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtEstoqueAtual" Text="0" FontSize="20" FontWeight="Bold" TextAlignment="Center" Background="#FEF08A" Height="35"/>
                            <Button Content="Alterar estoque (F5)" Height="25" Margin="0,5,0,20"/>

                            <CheckBox Content="Desativar produto?" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Histórico de Compra" FontWeight="Bold" FontSize="14"/>
            <TabItem Header="Histórico de Venda" FontWeight="Bold" FontSize="14"/>
            <TabItem Header="Conferência Estoque" FontWeight="Bold" FontSize="14"/>
            <TabItem Header="Grade/Variação" FontWeight="Bold" FontSize="14"/>
        </TabControl>
    </Grid>
</Window>