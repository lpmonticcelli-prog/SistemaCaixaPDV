<Window x:Class="SistemaCaixaPDV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDV Rápido" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize" Background="#E2E8F0"
        KeyDown="Window_KeyDown" Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#94A3B8" BlurRadius="10" ShadowDepth="1" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlowingTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00E1D9"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00E1D9" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="CAIXA ABERTO" FontSize="20" FontWeight="Black" Foreground="#10B981" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtRelogio" Text="12:00" FontSize="20" FontWeight="Bold" Foreground="#64748B" Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Venda:" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtNumeroVenda" Text="#00001" Foreground="#1E3A8A" FontWeight="Bold" Margin="5,0,20,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Data:" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtDataVenda" Text="01/01/2026" Foreground="#1E3A8A" FontWeight="Bold" Margin="5,0,20,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cliente:" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbCliente" Width="200" Margin="5,0,0,0" IsEditable="True" Text="CONSUMIDOR FINAL" Background="#F8FAFC" BorderBrush="#CBD5E1"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Content="[ESC] Sair" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,0" Cursor="Hand" Click="btnSair_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Background="#1E3A8A" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="QTD (Q)" Foreground="#94A3B8" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtQuantidadeTela" Text="1" Foreground="#00E1D9" FontWeight="Black" FontSize="45" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock Text="CÓDIGO DE BARRAS / PESQUISA (F3)" Foreground="#94A3B8" FontWeight="Bold" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtCodigoBarras" Height="55" FontSize="30" FontWeight="Bold" Background="White" BorderBrush="#00E1D9" BorderThickness="2" VerticalContentAlignment="Center" Padding="10,0" KeyDown="txtCodigoBarras_KeyDown"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,0,0,10" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="12">
                <Grid>
                    <Border x:Name="MascaraBanner" Background="White" CornerRadius="10"/>

                    <Image x:Name="imgPropaganda" Stretch="Fill">
                        <Image.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=MascaraBanner}"/>
                        </Image.OpacityMask>
                    </Image>
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Background="#F8FAFC" Padding="10">
                <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="[F2] Nova" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Padding="15,10" Cursor="Hand" Click="btnNovaVenda_Click"/>
                    <Button Content="[F4] Altera Qtd" Background="#64748B" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Padding="15,10" Cursor="Hand"/>
                    <Button Content="[F6] Excluir Item" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Padding="15,10" Cursor="Hand"/>
                    <Button Content="[F11] Desconto" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Padding="15,10" Cursor="Hand"/>
                    <Button Content="[F12] Sangria" Background="#8B5CF6" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" Padding="15,10" Cursor="Hand"/>
                    <Button Content="[F5] PAGAMENTO" Background="#10B981" Foreground="White" FontWeight="Black" FontSize="16" BorderThickness="0" Margin="20,5,5,5" Padding="20,10" Cursor="Hand" Click="btnDinheiro_Click"/>
                </WrapPanel>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="#1E3A8A" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,15" ClipToBounds="True">
                    <DataGrid x:Name="gridItens" PreviewKeyDown="gridItens_PreviewKeyDown" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" FontSize="14" RowHeight="35" 
                              Background="White" BorderThickness="0" HeadersVisibility="Column" GridLinesVisibility="None" AlternatingRowBackground="#F1F5F9">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Padding" Value="10,12"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nº" Binding="{Binding NumeroItem}" Width="40"/>
                            <DataGridTextColumn Header="Cód" Binding="{Binding Codigo}" Width="100"/>
                            <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*"/>
                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="50"/>
                            <DataGridTextColumn Header="Unitário" Binding="{Binding ValorUnitario, StringFormat=C}" Width="90"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Height="130" CornerRadius="10" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Image x:Name="imgProdutoAtual" Stretch="Uniform" Margin="10"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                            <TextBlock Text="PRODUTO REGISTRADO" Foreground="Gray" FontWeight="Bold" FontSize="12"/>
                            <TextBlock x:Name="txtDescricaoTela" Text="Aguardando..." FontWeight="Black" FontSize="30" Foreground="#1E293B" TextWrapping="Wrap" MaxHeight="80" TextTrimming="CharacterEllipsis" Margin="0,5"/>
                            <TextBlock x:Name="txtValorUnitarioTela" Text="R$ 0,00" FontWeight="Bold" FontSize="40" Foreground="#00E1D9"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#1E293B" CornerRadius="10" Padding="20" BorderBrush="#334155" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="ITENS" Foreground="#94A3B8" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtQtdTotalItens" Text="0" Foreground="White" FontWeight="Bold" FontSize="30" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <TextBlock Text="DESCONTOS" Foreground="#F59E0B" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtDescontoVisual" Text="R$ 0,00" Foreground="#F59E0B" FontWeight="Bold" FontSize="30" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Grid.Row="2" Background="#0F172A" CornerRadius="5" Padding="15">
                            <StackPanel>
                                <TextBlock Text="TOTAL A PAGAR" Foreground="#00E1D9" FontWeight="Black" FontSize="18" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtTotalVenda" Text="R$ 0,00" Foreground="White" FontWeight="Black" FontSize="75" HorizontalAlignment="Center" Margin="0,-10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>