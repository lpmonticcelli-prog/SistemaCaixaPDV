<Window x:Class="SistemaCaixaPDV.TelaRelatorios"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Central de Relatórios" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" Background="#F0F4F8" Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E3A8A" Padding="15">
            <StackPanel>
                <TextBlock Text="📊 RELATÓRIOS" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <Button x:Name="btnRelClientes" Content="👥 Lista de Clientes" Background="#3B82F6" Foreground="White" FontSize="16" FontWeight="SemiBold" Height="45" Margin="0,0,0,15" Click="btnRelClientes_Click"/>
                <Button x:Name="btnRelProdutos" Content="📦 Lista de Produtos" Background="#3B82F6" Foreground="White" FontSize="16" FontWeight="SemiBold" Height="45" Margin="0,0,0,15" Click="btnRelProdutos_Click"/>
                <Button x:Name="btnRelVendas" Content="💰 Histórico de Vendas" Background="#3B82F6" Foreground="White" FontSize="16" FontWeight="SemiBold" Height="45" Margin="0,0,0,15" Click="btnRelVendas_Click"/>

                <Separator Margin="0,20,0,20" Background="#60A5FA"/>

                <Button x:Name="btnImprimir" Content="🖨️ Imprimir Grid" Background="#10B981" Foreground="White" FontSize="16" FontWeight="Bold" Height="45" Margin="0,0,0,10" Click="btnImprimir_Click"/>
                <Button x:Name="btnFechar" Content="🚪 Sair" Background="#EF4444" Foreground="White" FontSize="16" FontWeight="Bold" Height="45" Click="btnFechar_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock x:Name="txtTituloRelatorio" Text="Selecione um relatório ao lado" FontSize="24" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,15"/>

                <Border x:Name="panelFiltrosVendas" Background="White" CornerRadius="8" Padding="15" Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Período:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                        <ComboBox x:Name="cbPeriodo" Width="150" Height="30" VerticalContentAlignment="Center" Margin="0,0,20,0" SelectionChanged="cbPeriodo_SelectionChanged">
                            <ComboBoxItem Content="Hoje" IsSelected="True"/>
                            <ComboBoxItem Content="Ontem"/>
                            <ComboBoxItem Content="Últimos 7 Dias"/>
                            <ComboBoxItem Content="Último Mês"/>
                            <ComboBoxItem Content="Personalizado (Calendário)"/>
                        </ComboBox>

                        <StackPanel x:Name="panelCalendario" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <DatePicker x:Name="dpInicio" Width="120" Height="30" Margin="0,0,15,0"/>

                            <TextBlock Text="Até:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <DatePicker x:Name="dpFim" Width="120" Height="30" Margin="0,0,15,0"/>
                        </StackPanel>

                        <Button x:Name="btnFiltrarVendas" Content="🔍 Buscar" Background="#1E3A8A" Foreground="White" FontWeight="Bold" Width="90" Height="30" Click="btnFiltrarVendas_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <DataGrid x:Name="gridResultados" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" 
                      Background="White" RowHeight="30" FontSize="14" AlternatingRowBackground="#F8FAFC"
                      HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="#E2E8F0"/>

            <Border x:Name="panelTotais" Grid.Row="2" Background="#FEF08A" CornerRadius="5" Padding="15" Margin="0,15,0,0" Visibility="Collapsed">
                <Grid>
                    <TextBlock Text="TOTAL NO PERÍODO:" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalRelatorio" Text="R$ 0,00" FontSize="24" FontWeight="Black" Foreground="#1E3A8A" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>