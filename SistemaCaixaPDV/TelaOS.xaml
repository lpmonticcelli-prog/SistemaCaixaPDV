<Window x:Class="SistemaCaixaPDV.TelaOS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ordem de Serviço" Height="768" Width="1024"
        WindowState="Maximized" WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        KeyDown="Window_KeyDown">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <CheckBox Content="Faturado" Margin="5,0,10,0" IsEnabled="False"/>
                <CheckBox x:Name="chkOrcamento" Content="Orçamento" Margin="0,0,10,0" IsChecked="True"/>
                <CheckBox Content="Em andamento" IsEnabled="False"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="SAIR" FontWeight="Bold" Foreground="Red" Cursor="Hand" MouseDown="Sair_MouseDown"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="0,1,0,1" Padding="0,5" Background="White">
            <WrapPanel Orientation="Horizontal">
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Click="btnNovaOS_Click">
                    <StackPanel>
                        <TextBlock Text="📄" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Nova OS - F2" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnSalvar" Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0" Click="btnSalvar_Click">
                    <StackPanel>
                        <TextBlock Text="💾" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Salvar OS - F4" FontSize="10" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="80" Height="60" Margin="2" Background="Transparent" BorderThickness="0">
                    <StackPanel>
                        <TextBlock Text="📝" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Alt. OS - F5" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Nº. OS:" VerticalAlignment="Center" FontWeight="Bold" Foreground="Gray" FontSize="14" Margin="5,0"/>
            <TextBox x:Name="txtNumOS" Grid.Column="1" Text="" Width="80" IsReadOnly="True" Background="#E0E0E0" TextAlignment="Right" VerticalContentAlignment="Center" FontSize="14"/>

            <TextBlock Grid.Column="2" Text="Cliente:" VerticalAlignment="Center" FontWeight="Bold" Foreground="Gray" FontSize="14" Margin="10,0,5,0"/>
            <ComboBox x:Name="cbCliente" Grid.Column="3" IsEditable="True" VerticalContentAlignment="Center" FontSize="14"/>
            <Button Grid.Column="4" Content="📋" Width="25" Margin="2,0,0,0"/>

            <TextBlock Grid.Column="5" Text="Responsável:" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold" Foreground="Gray" FontSize="14" Margin="10,0,5,0"/>
            <ComboBox x:Name="cbResponsavel" Grid.Column="6" IsEditable="True" Width="120" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Administrador" IsSelected="True"/>
                <ComboBoxItem Content="Técnico 1"/>
            </ComboBox>

            <TextBlock Grid.Column="7" Text="Data Entrada:" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="Gray" FontSize="12" Margin="10,0,5,0"/>
            <TextBox x:Name="txtDataEntrada" Grid.Column="8" Width="80" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Column="9" Text="Data Saída:" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="Gray" FontSize="12" Margin="10,0,5,0"/>
            <TextBox Grid.Column="10" Width="80" Background="#E0E0E0" IsReadOnly="True" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Column="11" Text="Status OS:" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold" Foreground="Gray" FontSize="16" Margin="10,0,5,0"/>
            <ComboBox x:Name="cbStatus" Grid.Column="12" IsEditable="True" Width="100" FontWeight="Bold" FontSize="14" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Aberto" IsSelected="True"/>
                <ComboBoxItem Content="Em Análise"/>
                <ComboBoxItem Content="Aguardando Peça"/>
                <ComboBoxItem Content="Aprovado"/>
                <ComboBoxItem Content="Concluído"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Tipo Produto:" VerticalAlignment="Center" FontWeight="Bold" Foreground="Gray" FontSize="14" Margin="5,0"/>
            <ComboBox x:Name="cbTipoProduto" Grid.Column="1" Background="#E0E0E0" IsEditable="True"/>

            <TextBlock Grid.Column="2" Text="Produto:" VerticalAlignment="Center" FontWeight="Bold" Foreground="Gray" FontSize="14" Margin="10,0,5,0"/>
            <TextBox x:Name="txtProduto" Grid.Column="3" Margin="0,0,27,0"/>
        </Grid>

        <UniformGrid Grid.Row="4" Columns="4">
            <Border BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Problema:" Background="Gray" Foreground="White" FontWeight="Bold" Padding="5,2"/>
                    <TextBox x:Name="txtProblema" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"/>
                </Grid>
            </Border>
            <Border BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Laudo:" Background="Gray" Foreground="White" FontWeight="Bold" Padding="5,2"/>
                    <TextBox x:Name="txtLaudo" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"/>
                </Grid>
            </Border>
            <Border BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Observações:" Background="Gray" Foreground="White" FontWeight="Bold" Padding="5,2"/>
                    <TextBox x:Name="txtObservacoes" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"/>
                </Grid>
            </Border>
            <Border BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Observações Internas:" Background="Gray" Foreground="White" FontWeight="Bold" Padding="5,2"/>
                    <TextBox x:Name="txtObsInternas" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"/>
                </Grid>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" Background="White">
                    <TabItem Header="⚙️ Produtos e Serviços" FontWeight="Bold">
                        <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column" Background="White" RowBackground="#B3D9FF" AlternatingRowBackground="White" GridLinesVisibility="All">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Código" Width="100"/>
                                <DataGridTextColumn Header="Descrição" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>

                <UniformGrid Grid.Row="1" Columns="6" Margin="0,5,0,0">
                    <StackPanel Margin="2">
                        <TextBlock Text="TOTAL BRUTO" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Height="30" IsReadOnly="True" FontSize="16" TextAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="2">
                        <TextBlock Text="DESCONTO" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Height="30" Text="R$ 0,00" Foreground="Blue" FontWeight="Bold" FontSize="16" TextAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="2">
                        <TextBlock Text="TOTAL LIQUIDO" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox x:Name="txtTotalLiquido" Height="30" Text="0,00" Background="#FFFF99" Foreground="Red" FontWeight="Bold" FontSize="16" TextAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Background="White">
                <TextBlock Text="Painel Lateral" Margin="10" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>