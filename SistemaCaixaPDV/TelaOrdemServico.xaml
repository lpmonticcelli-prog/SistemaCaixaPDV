<Window x:Class="SistemaCaixaPDV.TelaOrdemServico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ordem de Serviço - PDV Itapira" Height="768" Width="1366" 
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="#F0F0F0"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Height="60" Background="White" FontSize="14" Padding="5">
            <Button x:Name="btnNovaOS" Content="Nova OS - F2" Width="100" Margin="5,0" FontWeight="Bold"/>
            <Button x:Name="btnSalvarOS" Content="Salvar OS - F4" Width="110" Margin="5,0" />
            <Button x:Name="btnLocOS" Content="Loc. OS - F9" Width="100" Margin="5,0"/>
            <Separator Margin="10,0"/>
            <Button x:Name="btnImprimirA4" Content="Impr OS A4 - F6" Width="120" Margin="5,0"/>
            <Button x:Name="btnImprimir58" Content="Impr Cupom 58mm" Width="130" Margin="5,0"/>
            <Separator Margin="10,0"/>
            <Button x:Name="btnWhatsApp" Content="Enviar WhatsApp" Width="130" Margin="5,0" Foreground="Green" FontWeight="Bold"/>
            <Button x:Name="btnSair" Content="SAIR - ESC" Width="90" Margin="20,0,0,0" Foreground="Red" FontWeight="Bold" Click="btnSair_Click"/>
        </ToolBar>

        <Border DockPanel.Dock="Bottom" Background="#333333" Height="70" Padding="10">
            <UniformGrid Columns="6">
                <StackPanel Margin="5,0">
                    <TextBlock Text="TOTAL BRUTO" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox x:Name="txtTotalBruto" IsReadOnly="True" FontSize="18" FontWeight="Bold" TextAlignment="Center" Text="R$ 0,00"/>
                </StackPanel>
                <StackPanel Margin="5,0">
                    <TextBlock Text="DESCONTO" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox x:Name="txtDesconto" FontSize="18" FontWeight="Bold" Foreground="Blue" TextAlignment="Center" Text="R$ 0,00"/>
                </StackPanel>
                <StackPanel Margin="5,0">
                    <TextBlock Text="TOTAL LÍQUIDO" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox x:Name="txtTotalLiquido" IsReadOnly="True" Background="#FFFF99" FontSize="20" FontWeight="Bold" Foreground="Red" TextAlignment="Center" Text="R$ 0,00"/>
                </StackPanel>
                <StackPanel Margin="5,0">
                    <TextBlock Text="TOTAL ITENS" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox x:Name="txtTotalItens" IsReadOnly="True" FontSize="18" FontWeight="Bold" TextAlignment="Center" Text="0"/>
                </StackPanel>
                <StackPanel Margin="5,0">
                    <TextBlock Text="TOTAL PAGO" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox x:Name="txtTotalPago" IsReadOnly="True" FontSize="18" FontWeight="Bold" TextAlignment="Center" Text="R$ 0,00"/>
                </StackPanel>
                <StackPanel Margin="5,0">
                    <TextBlock Text="TROCO" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox x:Name="txtTroco" IsReadOnly="True" Background="#CCFFCC" FontSize="18" FontWeight="Bold" TextAlignment="Center" Text="R$ 0,00"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Nº OS:" FontWeight="Bold"/>
                    <TextBox x:Name="txtNumOS" FontSize="16" FontWeight="Bold" IsReadOnly="True" Background="#EAEAEA" TextAlignment="Center" Text="1"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Cliente:" FontWeight="Bold"/>
                    <ComboBox x:Name="cbCliente" FontSize="16" IsEditable="True"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Responsável:" FontWeight="Bold"/>
                    <ComboBox x:Name="cbResponsavel" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Data Entrada:" FontWeight="Bold"/>
                    <DatePicker x:Name="dpDataEntrada" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Data Saída:" FontWeight="Bold"/>
                    <DatePicker x:Name="dpDataSaida" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="5">
                    <TextBlock Text="Status OS:" FontWeight="Bold"/>
                    <ComboBox x:Name="cbStatus" FontSize="16" FontWeight="Bold">
                        <ComboBoxItem Content="Aberto" IsSelected="True"/>
                        <ComboBoxItem Content="Em Andamento"/>
                        <ComboBoxItem Content="Orçamento"/>
                        <ComboBoxItem Content="Aguardando Peça"/>
                        <ComboBoxItem Content="Finalizado"/>
                        <ComboBoxItem Content="Entregue"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,10">
                <GroupBox Header="Problema Relatado (Cliente):" Margin="0,0,5,0" FontWeight="Bold">
                    <TextBox x:Name="txtProblema" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontWeight="Normal"/>
                </GroupBox>
                <GroupBox Header="Laudo Técnico:" Margin="5,0" FontWeight="Bold">
                    <TextBox x:Name="txtLaudo" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontWeight="Normal"/>
                </GroupBox>
                <GroupBox Header="Observações (Aparece no Cupom):" Margin="5,0" FontWeight="Bold">
                    <TextBox x:Name="txtObservacoes" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontWeight="Normal"/>
                </GroupBox>
                <GroupBox Header="Observações Internas (Oculto):" Margin="5,0,0,0" FontWeight="Bold">
                    <TextBox x:Name="txtObsInterna" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontWeight="Normal" Background="#FFF9E6"/>
                </GroupBox>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0" Margin="0,0,10,0" FontSize="14">
                    <TabItem Header="Produtos e Serviços">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                                <TextBlock Text="Cód/Código Barras:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="txtBuscaProdutoOS" Width="200" FontSize="14" Padding="2" KeyDown="txtBuscaProdutoOS_KeyDown"/>
                                <TextBlock Text="(Aperte Enter)" Foreground="Gray" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>

                            <DataGrid x:Name="gridItensOS" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Un" Binding="{Binding Unidade}" Width="50" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Qtde" Binding="{Binding Quantidade}" Width="80"/>
                                    <DataGridTextColumn Header="Pc. Unitário" Binding="{Binding ValorUnitario, StringFormat=C}" Width="100"/>
                                    <DataGridTextColumn Header="Total Líquido" Binding="{Binding Subtotal, StringFormat=C}" Width="120" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Financeiro / Pagamento">
                        <StackPanel Margin="20">
                            <TextBlock Text="Esta aba será ativada ao faturar a OS." FontSize="16" Foreground="Gray"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <TabControl Grid.Column="1" FontSize="14">
                    <TabItem Header="Aparelho / Acessórios">
                        <StackPanel Margin="10">
                            <TextBlock Text="Nº Série / IMEI:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtImei" Height="25" Margin="0,0,0,15"/>

                            <TextBlock Text="Tipo Aparelho/Equipamento:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtEquipamento" Height="25" Margin="0,0,0,15"/>

                            <TextBlock Text="Marca / Modelo:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtMarcaModelo" Height="25" Margin="0,0,0,15"/>

                            <GroupBox Header="Acessórios Deixados" Margin="0,10,0,0" FontWeight="Bold">
                                <StackPanel Margin="5">
                                    <CheckBox Content="Carregador / Fonte" Margin="0,2"/>
                                    <CheckBox Content="Cabo USB" Margin="0,2"/>
                                    <CheckBox Content="Capa / Película" Margin="0,2"/>
                                    <CheckBox Content="Bateria" Margin="0,2"/>
                                    <CheckBox Content="Caixa Original" Margin="0,2"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Check List">
                        <StackPanel Margin="10">
                            <CheckBox Content="Equipamento Liga?" FontWeight="Bold" Margin="0,5"/>
                            <CheckBox Content="Tela/Display intactos?" Margin="0,5"/>
                            <CheckBox Content="Conector de carga ok?" Margin="0,5"/>
                            <CheckBox Content="Senhas fornecidas?" Margin="0,5"/>
                            <CheckBox Content="Garantia vigente?" Margin="0,5"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>