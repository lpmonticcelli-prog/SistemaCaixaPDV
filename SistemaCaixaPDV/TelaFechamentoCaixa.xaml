<Window x:Class="SistemaCaixaPDV.TelaFechamentoCaixa"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fechamento de Caixa" Height="650" Width="850"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#A0AEC0" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="15" Padding="20" Margin="10,0,10,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E3A8A" Offset="0.0"/>
                    <GradientStop Color="#3B82F6" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel>
                    <TextBlock Text="📊 RESUMO FINANCEIRO DO TURNO" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtDataFechamento" Text="Vendas do dia: 00/00/0000" FontSize="14" Foreground="#E0E7FF" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Receitas por Pagamento" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,10"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💵 Dinheiro:" Foreground="#333"/>
                        <TextBlock x:Name="txtVendaDinheiro" Grid.Column="1" Text="R$ 0,00" FontWeight="Bold" Foreground="#10B981"/>
                    </Grid>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📱 PIX:" Foreground="#333"/>
                        <TextBlock x:Name="txtVendaPix" Grid.Column="1" Text="R$ 0,00" FontWeight="Bold" Foreground="#00E1D9"/>
                    </Grid>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💳 Cartões:" Foreground="#333"/>
                        <TextBlock x:Name="txtVendaCartao" Grid.Column="1" Text="R$ 0,00" FontWeight="Bold" Foreground="#3B82F6"/>
                    </Grid>

                    <Separator Margin="0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TOTAL VENDIDO:" FontWeight="Bold" Foreground="#1E3A8A"/>
                        <TextBlock x:Name="txtTotalVendido" Grid.Column="1" Text="R$ 0,00" FontWeight="Black" FontSize="16" Foreground="#1E3A8A"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Movimentações (Gaveta)" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,10"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🟢 Suprimento (Troco):" Foreground="#333"/>
                        <TextBlock x:Name="txtSuprimento" Grid.Column="1" Text="R$ 0,00" FontWeight="Bold" Foreground="#16A34A"/>
                    </Grid>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔴 Sangria (Retirada):" Foreground="#333"/>
                        <TextBlock x:Name="txtSangria" Grid.Column="1" Text="R$ 0,00" FontWeight="Bold" Foreground="#DC2626"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="#10B981" Padding="15">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DINHEIRO NA GAVETA" FontWeight="Bold" FontSize="14" Foreground="#D1FAE5" HorizontalAlignment="Center"/>
                    <TextBlock Text="(Vendas Dinheiro + Suprimento - Sangria)" FontSize="10" Foreground="#A7F3D0" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtSaldoGaveta" Text="R$ 0,00" FontWeight="Black" FontSize="36" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🔒 Fechamento de Turno" FontSize="20" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Ao encerrar o turno, o sistema irá zerar os totais para o próximo operador." FontSize="14" Foreground="Gray" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock Text="Confira se o dinheiro físico na sua gaveta bate com o valor verde acima!" FontSize="14" FontWeight="SemiBold" Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="VOLTAR AO MENU" Background="#E2E8F0" Foreground="#333" FontWeight="Bold" Height="45" Width="180" HorizontalAlignment="Left" Click="btnVoltar_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" Content="ENCERRAR TURNO (ZERAR CAIXA)" Background="#DC2626" Foreground="White" FontWeight="Bold" FontSize="16" Height="45" Width="280" Click="btnEncerrarTurno_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>