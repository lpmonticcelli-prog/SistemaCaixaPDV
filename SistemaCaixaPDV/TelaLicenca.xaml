<Window x:Class="SistemaCaixaPDV.TelaLicenca"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ativação do Sistema" Height="400" Width="550"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" Background="#1E3A8A">

    <Border Background="White" CornerRadius="10" Margin="10" Padding="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="🔒 SISTEMA NÃO LICENCIADO" FontSize="24" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Para utilizar o sistema neste computador, entre em contato com o desenvolvedor e informe o código abaixo:" TextWrapping="Wrap" FontSize="14" Foreground="Gray" TextAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="CÓDIGO DESTA MÁQUINA:" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBox x:Name="txtCodigoMaquina" IsReadOnly="True" TextAlignment="Center" FontSize="24" FontWeight="Bold" Foreground="#1E3A8A" Background="#E5E7EB" BorderThickness="0" Height="40" Margin="0,5,0,20"/>

            <TextBlock Text="DIGITE A CHAVE DE LIBERAÇÃO:" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBox x:Name="txtChave" TextAlignment="Center" FontSize="24" FontWeight="Bold" Height="40" Margin="0,5,0,20"/>

            <Button Content="ATIVAR SISTEMA" Height="45" FontSize="16" FontWeight="Bold" Background="#16A34A" Foreground="White" Click="btnAtivar_Click"/>
        </StackPanel>
    </Border>
</Window>