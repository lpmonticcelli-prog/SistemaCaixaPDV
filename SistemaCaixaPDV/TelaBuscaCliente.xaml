<Window x:Class="SistemaCaixaPDV.TelaBuscaCliente"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Localizar Cliente" Height="450" Width="700"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" Background="#F0F4F8">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🔍 Nome ou CPF:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
            <TextBox x:Name="txtBusca" Width="400" Height="35" FontSize="16" VerticalContentAlignment="Center" KeyDown="txtBusca_KeyDown" Padding="5,0"/>
            <Button Content="Buscar" Width="100" Height="35" Margin="10,0,0,0" Background="#3B82F6" Foreground="White" FontWeight="Bold" Click="btnBuscar_Click"/>
        </StackPanel>

        <DataGrid x:Name="gridClientes" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  MouseDoubleClick="gridClientes_MouseDoubleClick" Background="White" RowHeight="30" FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="Nome do Cliente" Binding="{Binding Nome}" Width="*"/>
                <DataGridTextColumn Header="CPF / CNPJ" Binding="{Binding Cpf}" Width="150"/>
                <DataGridTextColumn Header="Celular" Binding="{Binding Telefone}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>