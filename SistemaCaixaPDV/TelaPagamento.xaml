<Window x:Class="SistemaCaixaPDV.TelaPagamento"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finalizar Venda" Height="672" Width="550"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" Background="#F8FAFC"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="💳 FINALIZAR PAGAMENTO" FontSize="22" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#10B981" CornerRadius="10" Padding="15" Margin="0,0,0,25">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="TOTAL DA VENDA" FontSize="14" FontWeight="Bold" Foreground="#D1FAE5" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtTotalPagar" Text="R$ 0,00" FontSize="40" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">

            <Grid x:Name="gridBotoes">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="255*"/>
                    <ColumnDefinition Width="41*"/>
                    <ColumnDefinition Width="214*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button x:Name="btnDinheiro" Grid.Row="0" Grid.Column="0" Background="#1E293B" Margin="5,75,5,189" Click="btnDinheiro_Click" Cursor="Hand" Grid.RowSpan="2">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="#334155" BorderThickness="2">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="💵" FontSize="30" HorizontalAlignment="Center"/>
                                    <TextBlock Text="[F1] DINHEIRO" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="btnPix" Grid.Row="0" Grid.Column="1" Background="#00E1D9" Margin="5,75,5,189" Click="btnPix_Click" Cursor="Hand" Grid.ColumnSpan="2" Grid.RowSpan="2">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="📱" FontSize="30" HorizontalAlignment="Center"/>
                                    <TextBlock Text="[F2] PIX" FontSize="16" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="btnCredito" Grid.Row="1" Grid.Column="0" Background="#3B82F6" Margin="5,39,5,5" Click="btnCredito_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="💳" FontSize="30" HorizontalAlignment="Center"/>
                                    <TextBlock Text="[F3] CRÉDITO" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="btnDebito" Grid.Row="1" Grid.Column="1" Background="#6366F1" Margin="5,39,5,5" Click="btnDebito_Click" Cursor="Hand" Grid.ColumnSpan="2">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="💳" FontSize="30" HorizontalAlignment="Center"/>
                                    <TextBlock Text="[F4] DÉBITO" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border x:Name="panelPix" Visibility="Collapsed" Background="White" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="15" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ESCANEIE PARA PAGAR" FontSize="16" FontWeight="Bold" Foreground="#00E1D9" HorizontalAlignment="Center"/>

                    <Image x:Name="imgQrCode" Grid.Row="1" Width="180" Height="180" Margin="0,10,0,10"/>

                    <TextBlock x:Name="txtChavePixTela" Grid.Row="2" Text="Chave: ..." FontSize="14" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="CANCELAR" Height="40" Background="#E2E8F0" FontWeight="Bold" Margin="0,0,5,0" Click="btnVoltarPix_Click" Cursor="Hand"/>
                        <Button Grid.Column="1" Content="CONFIRMAR RECEBIMENTO" Height="40" Background="#10B981" Foreground="White" FontWeight="Bold" Margin="5,0,0,0" Click="btnConfirmarPix_Click" Cursor="Hand"/>
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>